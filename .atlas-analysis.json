  "keyFeatures": [
    "Product import and sync between Shopify, Ecomdrop, and Dropi",
    "AI-powered customer support configuration",
    "Automated order processing and flow management",
    "Programmatic theme installation and management",
    "Real-time webhooks for order and checkout events",
    "MySQL database with Prisma ORM",
    "Docker-ready containerized deployment",
    "Modern React UI with Tailwind CSS and shadcn/ui"
  ],
  "publicApiSurface": [
    "POST /api/products/import - Import products from Dropi to Shopify",
    "GET /api/dropi/products - Fetch available Dropi products",
    "POST /api/integrations/dropi/save - Save Dropi integration settings",
    "POST /api/ecomdrop/callback - Handle Ecomdrop webhook callbacks",
    "POST /api/orders/poll - Poll and process pending orders",
    "POST /api/theme/install - Install theme from Git repository",
    "GET /api/theme/download/:id - Download theme assets",
    "GET /api/shopify/products - List Shopify products",
    "GET /api/shopify/product/variants - Get product variants",
    "DELETE /api/products/association/delete - Remove product associations",
    "POST /webhooks/orders/create - Webhook for new orders",
    "POST /webhooks/draft_orders/create - Webhook for draft orders"
  ]
}
